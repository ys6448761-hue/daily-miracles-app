# GA4 Measurement ID
# Render Dashboard > Environment > Add Environment Variable
# 키: VITE_GA4_ID
# 값: G-XXXXXXXXXX  (GA4 측정 ID)
VITE_GA4_ID=G-XXXXXXXXXX

# 카카오 JavaScript SDK 앱 키
# Render Dashboard > Environment > Add Environment Variable
# 키: VITE_KAKAO_JS_KEY
# 값: 카카오 개발자 콘솔 > 내 앱 > JavaScript 키
VITE_KAKAO_JS_KEY=
